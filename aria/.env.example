# ─────────────────────────────────────────────────────────────────────────────
# Aria — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env — it's in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...

# ── EAS (Expo Application Services) ──────────────────────────────────────────
# Created after running: cd aria && npx eas-cli init
# expo.dev → your project → Project ID
EXPO_PUBLIC_EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── Sentry (optional — crash reporting) ──────────────────────────────────────
# sentry.io → your project → Settings → Client Keys (DSN)
EXPO_PUBLIC_SENTRY_DSN=

# ─────────────────────────────────────────────────────────────────────────────
# The following keys are NEVER stored here.
# They live only as Supabase Edge Function secrets:
#   supabase secrets set KEY=value
#
#   DEEPGRAM_API_KEY              → voice-transcribe function
#   ANTHROPIC_API_KEY             → ai-parse function
#   GOOGLE_PROJECT_ID             → document-scan function
#   GOOGLE_DOCAI_EXPENSE_PROCESSOR_ID → document-scan function
#   GOOGLE_ACCESS_TOKEN           → document-scan function
#   EXPO_ACCESS_TOKEN             → notifications-send function
# ─────────────────────────────────────────────────────────────────────────────
